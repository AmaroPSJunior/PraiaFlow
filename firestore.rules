rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: menu
    // Fields: name (string), description (string), price (number), category (string), available (bool), imageUrl (string)
    //
    // Collection: orders
    // Fields: tableId (string), items (list with observations), total (number), status (string), paymentMethod (string), paymentStatus (string), createdAt (timestamp), updatedAt (timestamp)
    //
    // Collection: tables
    // Fields: number (number), active (bool)
    //
    // Collection: users
    // Fields: uid (string), email (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "arcamos.j@gmail.com"));
    }

    function isWaiter() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'waiter';
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.available is bool;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.icon is string;
    }

    function isValidOrder(data) {
      return data.tableId is string &&
             data.userId is string &&
             data.orderNumber is number &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'paid', 'preparing', 'ready', 'delivered', 'cancelled'] &&
             data.paymentMethod in ['pix', 'card'] &&
             data.paymentStatus in ['pending', 'paid', 'failed'];
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'staff', 'waiter', 'client'];
    }

    // Rules
    match /menu/{itemId} {
      allow read: if true; // Public menu access
      allow create, update: if true; // Relaxed for dev
      allow delete: if true; // Relaxed for dev
    }

    match /categories/{catId} {
      allow read: if true;
      allow create, update: if true; // Relaxed for dev
      allow delete: if true; // Relaxed for dev
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if true; // Relaxed for dev
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if true; // Relaxed for dev
    }

    match /orders/{orderId} {
      allow read: if true; 
      allow create: if true; // Relaxed for dev
      allow update: if true; // Relaxed for dev
      allow delete: if true; // Relaxed for dev
    }

    match /users/{userId} {
      allow read: if true; // Relaxed for dev
      allow create: if true; // Relaxed for dev
      allow update: if true; // Relaxed for dev
      allow delete: if true; // Relaxed for dev
    }

    match /audit_logs/{logId} {
      allow read: if true; // Relaxed for dev
      allow create: if true; // Relaxed for dev
    }

    match /metadata/{docId} {
      allow read: if true; // Relaxed for dev
      allow write: if true; // Relaxed for dev
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow write: if true; // Relaxed for dev
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true; // Relaxed for dev
    }

    match /waiter_calls/{callId} {
      allow read: if true; // Relaxed for dev
      allow create: if true; // Relaxed for dev
      allow update, delete: if true; // Relaxed for dev
    }

    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
